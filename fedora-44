# ============================================================
# SETUP EXTRA DISKS (BITLOCKER & NVMe-SAFE PARTITION HANDLING)
# ============================================================
setup_secondary_disk(){
  info "Starting disk setup..."
  install_if_missing util-linux parted ntfs-3g ntfsprogs exfatprogs btrfs-progs xfsprogs

  local USERNAME USERID GROUPID
  USERNAME="$(current_user)"
  USERID="$(id -u "$USERNAME")"
  GROUPID="$(id -g "$USERNAME")"

  local ROOT_DISK
  ROOT_DISK="$(root_backing_disk 2>/dev/null || true)"

  echo "=== Available Disks ==="
  mapfile -t DISKS < <(lsblk -dpno NAME,TYPE | awk '$2=="disk"{print $1}')
  if (( ${#DISKS[@]} == 0 )); then
    error "No disks found."
    return 1
  fi

  local i=1 DISK SIZE MARKER
  for DISK in "${DISKS[@]}"; do
    SIZE="$(lsblk -dnbo SIZE "$DISK" | numfmt --to=iec-i --suffix=B)"
    MARKER=""
    [[ -n "$ROOT_DISK" && "$DISK" == "$ROOT_DISK" ]] && MARKER=" [ROOT/SYSTEM DISK]"
    echo "[$i] $DISK ($SIZE)$MARKER"
    i=$((i+1))
  done

  local DISK_NUMBER SELECTED_DISK
  while true; do
    read -r -p "Select disk number: " DISK_NUMBER
    if [[ "$DISK_NUMBER" =~ ^[0-9]+$ ]] && \
       (( DISK_NUMBER >= 1 && DISK_NUMBER <= ${#DISKS[@]} )); then
      SELECTED_DISK="${DISKS[$((DISK_NUMBER-1))]}"
      break
    fi
    warn "Invalid selection. Try again."
  done

  echo "=== Partitions on $SELECTED_DISK ==="
  mapfile -t PART_INFO < <(
    lsblk -nrpo NAME,SIZE,FSTYPE,MOUNTPOINT,TYPE "$SELECTED_DISK" |
      awk '$5=="part"{print $1 "|" $2 "|" $3 "|" $4}'
  )

  if (( ${#PART_INFO[@]} == 0 )); then
    warn "No partitions found on $SELECTED_DISK."

    if [[ -n "$ROOT_DISK" && "$SELECTED_DISK" == "$ROOT_DISK" ]]; then
      error "Refusing to erase the detected root/system disk: $SELECTED_DISK"
      warn "To override, you must type ERASE-SYSTEM-DISK exactly. This is intentionally difficult."
      confirm_text "Type ERASE-SYSTEM-DISK to continue, or anything else to cancel:" "ERASE-SYSTEM-DISK" || return 1
    fi

    if ! ask_user "Create a new full-disk partition on $SELECTED_DISK? THIS ERASES DATA"; then
      warn "Partition creation skipped."
      return 1
    fi

    confirm_text "Final destructive confirmation. Type ERASE to wipe $SELECTED_DISK:" "ERASE" || { warn "Erase cancelled."; return 1; }

    local FS_CHOICE
    echo "Choose filesystem for the new partition:"
    select FS_CHOICE in ext4 xfs btrfs ntfs; do
      case "$FS_CHOICE" in
        ext4|xfs|btrfs|ntfs) break ;;
        *) echo "Invalid choice" ;;
      esac
    done

    info "Creating GPT partition table on $SELECTED_DISK"
    sudo parted -s "$SELECTED_DISK" mklabel gpt
    sudo parted -s "$SELECTED_DISK" mkpart primary 1MiB 100%

    info "Informing kernel of partition changes"
    sudo partprobe "$SELECTED_DISK"
    sleep 2

    local NEW_PARTITION
    NEW_PARTITION="$(lsblk -nrpo NAME,TYPE "$SELECTED_DISK" | awk '$2=="part"{print $1; exit}')"
    if [[ -z "$NEW_PARTITION" ]]; then
      error "Could not detect new partition on $SELECTED_DISK."
      return 1
    fi

    info "Formatting $NEW_PARTITION as $FS_CHOICE"
    case "$FS_CHOICE" in
      ext4) sudo mkfs.ext4 -F "$NEW_PARTITION" ;;
      xfs) sudo mkfs.xfs -f "$NEW_PARTITION" ;;
      btrfs) sudo mkfs.btrfs -f "$NEW_PARTITION" ;;
      ntfs) sudo mkfs.ntfs -f "$NEW_PARTITION" ;;
    esac

    PART_INFO=("$NEW_PARTITION|$(lsblk -dnbo SIZE "$NEW_PARTITION" | numfmt --to=iec-i --suffix=B)|$FS_CHOICE|")
  fi

  i=1
  local LINE PNAME PSIZE PFSTYPE PMOUNT
  for LINE in "${PART_INFO[@]}"; do
    IFS="|" read -r PNAME PSIZE PFSTYPE PMOUNT <<< "$LINE"
    [[ -z "$PFSTYPE" ]] && PFSTYPE="unknown"
    [[ -z "$PMOUNT" ]] && PMOUNT="-"
    echo "[$i] $PNAME ($PSIZE) fstype=$PFSTYPE mount=$PMOUNT"
    i=$((i+1))
  done

  local PART_NUMBER PARTITION
  while true; do
    read -r -p "Select partition number: " PART_NUMBER
    if [[ "$PART_NUMBER" =~ ^[0-9]+$ ]] && \
       (( PART_NUMBER >= 1 && PART_NUMBER <= ${#PART_INFO[@]} )); then
      IFS="|" read -r PARTITION _ <<< "${PART_INFO[$((PART_NUMBER-1))]}"
      break
    fi
    warn "Invalid selection. Try again."
  done

  if findmnt -rn --source "$PARTITION" >/dev/null 2>&1; then
    warn "Partition is already mounted."
    return 0
  fi

  if sudo blkid "$PARTITION" | grep -iq bitlocker; then
    warn "BitLocker detected."
    install_if_missing dislocker fuse-dislocker
    sudo mkdir -p /mnt/bitlocker /mnt/data
    read -r -s -p "Enter BitLocker password: " BL_PASS
    echo
    sudo dislocker -V "$PARTITION" -u"$BL_PASS" -- /mnt/bitlocker
    sudo mount -o loop,uid="$USERID",gid="$GROUPID" \
      /mnt/bitlocker/dislocker-file /mnt/data
    info "Mounted BitLocker volume at /mnt/data"
    warn "BitLocker mount is session-only and is intentionally not added to /etc/fstab."
    return 0
  fi

  local FS_TYPE UUID MOUNT_NAME MOUNT_DIR OPTS FSTAB_TYPE
  FS_TYPE="$(blkid -s TYPE -o value "$PARTITION" 2>/dev/null || true)"
  if [[ -z "$FS_TYPE" ]]; then
    error "Could not determine filesystem type for $PARTITION."
    return 1
  fi

  read -r -p "Enter mount folder name under /mnt (e.g. storage): " MOUNT_NAME
  MOUNT_NAME="$(echo "$MOUNT_NAME" | tr -cd '[:alnum:]_.-')"
  [[ -n "$MOUNT_NAME" ]] || { error "Empty/invalid mount folder name."; return 1; }
  MOUNT_DIR="/mnt/$MOUNT_NAME"
  sudo mkdir -p "$MOUNT_DIR"

  UUID="$(blkid -s UUID -o value "$PARTITION")"
  if [[ -z "$UUID" ]]; then
    error "Could not determine UUID for $PARTITION."
    return 1
  fi

  case "$FS_TYPE" in
    ntfs)
      FSTAB_TYPE="ntfs3"
      OPTS="defaults,nofail,x-systemd.device-timeout=5s,uid=$USERID,gid=$GROUPID,umask=000"
      ;;
    vfat|fat|exfat)
      FSTAB_TYPE="$FS_TYPE"
      OPTS="defaults,nofail,x-systemd.device-timeout=5s,uid=$USERID,gid=$GROUPID,umask=000"
      ;;
    *)
      FSTAB_TYPE="$FS_TYPE"
      OPTS="defaults,nofail,x-systemd.device-timeout=5s"
      ;;
  esac

  backup_file /etc/fstab
  if ! sudo grep -q "UUID=$UUID" /etc/fstab; then
    echo "UUID=$UUID $MOUNT_DIR $FSTAB_TYPE $OPTS 0 2" | sudo tee -a /etc/fstab >/dev/null
  else
    warn "UUID already exists in /etc/fstab; not adding duplicate."
  fi

  sudo mount -a
  info "Disk mounted at $MOUNT_DIR"
}

if ask_user "Setup a second internal disk (Mount/BitLocker)?"; then
  setup_secondary_disk
